{
  "db_name": "PostgreSQL",
  "query": "\n              SELECT\n                u.id,\n                u.name,\n                u.created_at,\n                u.updated_at,\n                a.kind::text as \"kind!: String\",\n                a.email,\n                a.password_hash,\n                a.provider,\n                a.provider_user_id,\n                a.created_at as auth_created_at,\n                a.updated_at as auth_updated_at\n              FROM users u\n              INNER JOIN user_auth a ON a.user_id = u.id\n              WHERE u.id = $1\n            ",
